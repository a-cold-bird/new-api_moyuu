# Copy to .env before starting Docker Compose.

# Application
TZ=Asia/Shanghai
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true

# Secrets
# Generate with:
#   openssl rand -hex 32
SESSION_SECRET=replace_with_a_random_hex_string
CRYPTO_SECRET=replace_with_a_random_hex_string

# Database
# This project auto-detects PostgreSQL by the DSN prefix.
# The host PostgreSQL service runs on the Linux host, not in Compose.
# `host.docker.internal` is mapped by docker-compose.yml to the host gateway.
SQL_DSN=postgresql://newapi:replace_with_strong_password@host.docker.internal:5432/newapi?sslmode=disable
SQL_MAX_IDLE_CONNS=20
SQL_MAX_OPEN_CONNS=100
SQL_MAX_LIFETIME=600

# Redis
REDIS_CONN_STRING=redis://redis:6379/0

# Optional
# STREAMING_TIMEOUT=300
# SYNC_FREQUENCY=60
